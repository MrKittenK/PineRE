#!/bin/bash
# R36 Ultra System Control Tool - CORRECTED VERSION
# Provides hardware acceleration options and system utilities
#
# LEARNING: This script demonstrates proper error handling and input validation
# for system configuration utilities

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

# LEARNING: Validate that we're running as root before system changes
check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "ERROR: This command requires root privileges"
        echo "Try: sudo $0"
        return 1
    fi
}

# LEARNING: Verify sysfs path exists before attempting modification
check_cpufreq_available() {
    if [ ! -d "/sys/devices/system/cpu/cpufreq/policy0" ]; then
        echo "ERROR: CPUFreq subsystem not available"
        return 1
    fi
}

# ============================================================================
# HARDWARE ACCELERATION OPTIONS
# ============================================================================

apply_performance_mode() {
    # LEARNING: Set CPU governor to 'performance' mode
    # This disables dynamic frequency scaling for maximum performance
    # Trade-off: Higher power consumption, more heat
    
    check_root || return 1
    check_cpufreq_available || return 1
    
    echo "Applying Performance Mode (1.5GHz max)..."
    
    # LEARNING: Check if write succeeds before continuing
    # This prevents silent failures if the path is read-only
    if echo "performance" > /sys/devices/system/cpu/cpufreq/policy0/scaling_governor; then
        echo "✓ Governor set to: performance"
    else
        echo "ERROR: Failed to set scaling governor"
        return 1
    fi
    
    # LEARNING: Set maximum CPU frequency to 1.5GHz (1512000 kHz)
    # The RK3326 in R36 Ultra is typically limited to this
    if echo 1512000 > /sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq; then
        echo "✓ Max frequency set to: 1512MHz (1.5GHz)"
    else
        echo "ERROR: Failed to set frequency"
        return 1
    fi
}

apply_powersave_mode() {
    # LEARNING: Set CPU governor to 'powersave' mode
    # This minimizes frequency to reduce power consumption
    # Trade-off: Lower performance, longer battery life
    
    check_root || return 1
    check_cpufreq_available || return 1
    
    echo "Applying Power Save Mode..."
    
    if echo "powersave" > /sys/devices/system/cpu/cpufreq/policy0/scaling_governor; then
        echo "✓ Governor set to: powersave"
    else
        echo "ERROR: Failed to set scaling governor"
        return 1
    fi
}

# ============================================================================
# MEMORY OPTIMIZATION
# ============================================================================

apply_zram() {
    # LEARNING: ZRAM provides transparent compression of swap memory
    # Benefits: Reduced physical memory pressure, faster swap than disk
    # Trade-off: CPU overhead for compression/decompression
    # Typical setup: 512MB compressed = ~1GB effective (50% ratio)
    
    check_root || return 1
    
    echo "Initializing ZRAM (Compressed Virtual Memory)..."
    
    # LEARNING: Load zram kernel module if not already loaded
    if ! grep -q "^zram" /proc/modules 2>/dev/null; then
        echo "Loading zram module..."
        if ! modprobe zram; then
            echo "ERROR: Failed to load zram module"
            return 1
        fi
    fi
    
    # LEARNING: Check if zram0 already initialized to prevent double-setup
    if [ -f /sys/block/zram0/disksize ] && [ "$(cat /sys/block/zram0/disksize)" != "0" ]; then
        echo "WARNING: ZRAM already initialized, skipping"
        return 0
    fi
    
    # LEARNING: Set disksize to 512MB (536870912 bytes = 512*1024*1024)
    # This is the compressed space allocated for ZRAM
    echo 536870912 > /sys/block/zram0/disksize || {
        echo "ERROR: Failed to set ZRAM disksize"
        return 1
    }
    
    # LEARNING: Format ZRAM as swap space
    mkswap /dev/zram0 || {
        echo "ERROR: Failed to format ZRAM as swap"
        return 1
    }
    
    # LEARNING: Enable swap on ZRAM with priority 10
    # Higher priority means ZRAM is used before disk swap
    swapon /dev/zram0 -p 10 || {
        echo "ERROR: Failed to enable ZRAM swap"
        return 1
    }
    
    echo "✓ ZRAM initialized (512MB compressed swap)"
}

# ============================================================================
# SYSTEM UTILITIES
# ============================================================================

open_file_manager() {
    # LEARNING: Midnight Commander is a terminal-based file manager
    # Useful for navigating filesystem without graphics
    echo "Launching File Manager (Midnight Commander)..."
    mc
}

# ============================================================================
# MENU INTERFACE
# ============================================================================

show_menu() {
    # LEARNING: Simple text menu for interactive control
    clear 2>/dev/null || true
    
    cat << 'EOF'
========================================
   R36 Ultra Control Center
========================================

1) Performance Mode (1.5GHz max clock)
2) Power Save Mode (minimize frequency)
3) Initialize ZRAM (512MB compressed swap)
4) File Manager (Midnight Commander)
5) Exit

========================================
EOF
    
    read -rp "Selection [1-5]: " choice
    
    # LEARNING: Case statement handles each menu option
    case "$choice" in
        1)
            apply_performance_mode
            ;;
        2)
            apply_powersave_mode
            ;;
        3)
            apply_zram
            ;;
        4)
            open_file_manager
            ;;
        5)
            echo "Exiting..."
            exit 0
            ;;
        *)
            echo "ERROR: Invalid selection '$choice'"
            sleep 2
            ;;
    esac
    
    # LEARNING: Wait before redrawing menu to show operation result
    read -rp "Press Enter to continue..."
}

# ============================================================================
# MAIN LOOP
# ============================================================================

# LEARNING: Infinite loop allows menu to stay open after each operation
# User can perform multiple operations without restarting script
while true; do
    show_menu
done
