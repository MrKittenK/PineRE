#!/bin/bash
# ============================================================================
# R36 ULTRA SYSTEM INTEGRATION SCRIPT - FINAL PRODUCTION INTEGRATED VERSION
# ============================================================================

# --- PART 1: BROADCAST WRAPPER ---
FIFO_COMM="/tmp/r36u_gui_comm.fifo"
[ -p "$FIFO_COMM" ] || mkfifo "$FIFO_COMM"

mirror_log() {
    echo "$*" >&2
    if [ -p "$FIFO_COMM" ]; then echo "$*" > "$FIFO_COMM"; fi
}
export -f mirror_log

exec 3>&1 4>&2
exec > >(stdbuf -oL -eL bash -c 'while read -r line; do mirror_log "$line"; done') 2>&1

log_info() { mirror_log "[INFO] $*"; }
log_warn() { mirror_log "[WARN] $*"; }
log_error() { mirror_log "[ERROR] $*"; }
log_fatal() { mirror_log "[FATAL] $*"; exit 1; }


# (I have preserved your exact logic below, no edits needed)

set -euo pipefail 

# [BEGIN YOUR ORIGINAL LOGIC]
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORKING_DIR="${WORKING_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
ROOTFS="/mnt/r36ultra_root"
BOOTFS="/mnt/r36ultra_boot"
TARGET_DEV="${RUN_TARGET_DEV:-}"
LOG_FILE="/tmp/r36ultra_setup_$(date +%s).log"

# LEARNING: Always log output for post-failure analysis
exec 1> >(tee -a "$LOG_FILE")
exec 2>&1

echo "================================================================================"
echo "R36 Ultra OS Integration Script - $(date)"
echo "Log file: $LOG_FILE"
echo "================================================================================"

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

# LEARNING: Helper functions reduce code duplication and improve readability
log_info() {
    echo "[INFO] $*"
}

log_warn() {
    echo "[WARN] $*" >&2
}

log_error() {
    echo "[ERROR] $*" >&2
}

log_fatal() {
    echo "[FATAL] $*" >&2
    exit 1
}

# LEARNING: User confirmation prevents accidental data loss
# This function is safe and handles multiple input types
confirm() {
    local prompt="$1"
    local response
    
    while true; do
        read -rp "$prompt [y/N]? " response
        case "$response" in
            [yY][eE][sS]|[yY]) return 0 ;;
            [nN][oO]|[nN]|"") return 1 ;;
            *) log_warn "Please answer yes or no" ;;
        esac
    done
}

# LEARNING: File integrity verification prevents corruption during copy
# Uses checksums to verify data integrity across the copy operation
verify_copy() {
    local src="$1"
    local dst="$2"
    local src_hash dst_hash
    
    if [ ! -f "$src" ]; then
        log_error "Source file not found: $src"
        return 1
    fi
    
    if [ ! -f "$dst" ]; then
        log_error "Destination file not found: $dst"
        return 1
    fi
    
    # LEARNING: On slow SD cards or handheld hardware, the OS may cache writes.
    # Syncing before hashing ensures we are reading what was actually written 
    # to the physical media, catching "silent" failures or fake-capacity issues.
    sync

    # LEARNING: md5sum produces two fields; we extract the first (hash)
    src_hash=$(md5sum "$src" | awk '{print $1}')
    dst_hash=$(md5sum "$dst" | awk '{print $1}')
    
    if [ "$src_hash" != "$dst_hash" ]; then
        log_error "Checksum mismatch for $(basename "$src")!"
        log_error "  Source: $src_hash"
        log_error "  Dest:   $dst_hash"
        return 1
    fi
    
    log_info "✓ Verified $(basename "$src"): $src_hash"
    return 0
}

# LEARNING: Safely escape strings for use in sed replacement
# This prevents sed from interpreting special characters (/, \, &, etc.)
# as metacharacters when they appear in the replacement string
escape_sed_replacement() {
    local string="$1"
    # Escape backslash, forward slash, and ampersand
    printf '%s\n' "$string" | sed -e 's/[\/&]/\\&/g'
}

# LEARNING: Check if a block device is mounted anywhere on the system
# This prevents data loss from accidentally writing to active filesystems
is_device_mounted() {
    local device="$1"
    
    # LEARNING: /proc/mounts is more reliable than findmnt for this check
    # It directly reads kernel mount table
    grep -q "^${device}" /proc/mounts
}

# LEARNING: Detect partition naming convention
# Different device types use different partition naming:
# - /dev/sdX1, /dev/sdbX1 (SATA/USB - no 'p')
# - /dev/nvme0n1p1 (NVMe - has 'p')
# - /dev/mmcblk0p1 (eMMC - has 'p')
get_partition_suffix() {
    local device="$1"
    
    # LEARNING: Pattern matching in bash [[ ]] without quotes is safe here
    # because we control the device variable
    if [[ "$device" == /dev/nvme* ]] || [[ "$device" == /dev/mmcblk* ]]; then
        echo "p"
    else
        echo ""
    fi
}

# LEARNING: Ensure U-Boot binaries are available (download or extract)
# This function checks for required U-Boot files and offers to extract them
# from an ArkOS .img file if they're missing. Stores them in WORKING_DIR
# for future use to avoid re-downloading.
ensure_uboot_binaries() {
    local idbloader="$WORKING_DIR/idbloader.img"
    local uboot_itb="$WORKING_DIR/u-boot.itb"
    
    # LEARNING: Check if both binaries already exist (cached locally)
    if [ -f "$idbloader" ] && [ -f "$uboot_itb" ]; then
        log_info "✓ U-Boot binaries found (cached in $WORKING_DIR)"
        return 0
    fi
    
    log_warn ""
    log_warn "U-Boot binaries not found in $WORKING_DIR"
    log_info ""
    
    # LEARNING: First check if arkos.img exists in the same folder as this script
    local script_dir="$(dirname "${BASH_SOURCE[0]}")"
    local arkos_img="${script_dir}/arkos.img"
    
    if [ -f "$arkos_img" ]; then
        log_info "✓ Found arkos.img in script directory: $arkos_img"
        log_info "Automatically extracting U-Boot binaries..."
    else
        log_info "Options to obtain U-Boot binaries:"
        log_info "  1. Extract from ArkOS .img file (recommended)"
        log_info "  2. Copy existing binaries from another location"
        log_info ""
        
        if ! confirm "Extract U-Boot from ArkOS .img file"; then
            log_error "U-Boot binaries are required to boot the device"
            log_error "Please provide idbloader.img and u-boot.itb in $WORKING_DIR"
            return 1
        fi
        
        read -rp "Enter path to ArkOS .img file: " arkos_img
        
        # LEARNING: Expand ~ and other path expansions
        arkos_img="${arkos_img/#\~/$HOME}"
        
        if [ ! -f "$arkos_img" ]; then
            log_fatal "File not found: $arkos_img"
        fi
    fi
    
    log_info ""
    log_info "Extracting U-Boot SPL (idbloader.img) from ArkOS image..."
    # LEARNING: Extract idbloader from sector 64, count 16320 (0x4000 sectors)
    # This is the RK3326 bootloader SPL location
    if ! dd if="$arkos_img" of="$idbloader" bs=512 skip=64 count=16320 2>/dev/null; then
        log_fatal "Failed to extract idbloader.img"
    fi
    
    # LEARNING: Verify extraction - file should be ~8MB
    if [ ! -f "$idbloader" ] || [ ! -s "$idbloader" ]; then
        log_fatal "idbloader.img extraction failed or produced empty file"
    fi
    local idb_size=$(du -h "$idbloader" | cut -f1)
    log_info "✓ idbloader.img extracted: $idb_size"
    
    log_info "Extracting U-Boot proper (u-boot.itb) from ArkOS image..."
    # LEARNING: Extract u-boot.itb from sector 16384, count 8192
    # This is the RK3326 U-Boot proper location
    if ! dd if="$arkos_img" of="$uboot_itb" bs=512 skip=16384 count=8192 2>/dev/null; then
        log_fatal "Failed to extract u-boot.itb"
    fi
    
    # LEARNING: Verify extraction - file should be ~4MB
    if [ ! -f "$uboot_itb" ] || [ ! -s "$uboot_itb" ]; then
        log_fatal "u-boot.itb extraction failed or produced empty file"
    fi
    local uboot_size=$(du -h "$uboot_itb" | cut -f1)
    log_info "✓ u-boot.itb extracted: $uboot_size"
    
    log_info ""
    log_info "✓ U-Boot binaries extracted and cached in $WORKING_DIR"
    log_info "  These will be reused for future flashing operations"
    return 0
}

# ============================================================================
# PRE-FLIGHT CHECKS
# ============================================================================

log_info "Running pre-flight checks..."

# LEARNING: Check for all required commands upfront
# Failing early prevents partial operations
declare -a REQUIRED_CMDS=(
    "mkimage" "dd" "find" "grep" "sed" "bc" "parted" 
    "mkfs.vfat" "mkfs.ext4" "md5sum" "blkid" "mount" "umount"
)

for cmd in "${REQUIRED_CMDS[@]}"; do
    if ! command -v "$cmd" &>/dev/null; then
        log_fatal "Required command not found: $cmd"
    fi
done
log_info "✓ All required commands available"

# LEARNING: Verify we're running as root (required for mount/dd operations)
if [ "$(id -u)" -ne 0 ]; then
    log_fatal "This script must be run as root (use: sudo $0)"
fi
log_info "✓ Running as root"

# LEARNING: Verify working directory structure
if [ ! -f "$WORKING_DIR/boot.ini" ]; then
    log_fatal "boot.ini not found in $WORKING_DIR"
fi
for file in boot.ini Image uInitrd rk3326-r36ultra-linux.dtb; do
    if [ ! -f "$WORKING_DIR/$file" ]; then
        log_fatal "Required boot file missing in $WORKING_DIR: $file"
    fi
done
log_info "✓ Working directory structure verified"

# ============================================================================
# TARGET DEVICE SELECTION
# ============================================================================

log_info ""
log_info "Selecting target SD card device..."

if [ -z "$TARGET_DEV" ]; then
    log_info "Available block devices:"
    lsblk -d -n -o NAME,SIZE,TYPE
    
    read -rp "Enter target SD card device (e.g., /dev/sdX): " TARGET_DEV
fi

TARGET_DEV="${TARGET_DEV#/dev/}"  # Remove /dev/ prefix if user included it
TARGET_DEV="/dev/$TARGET_DEV"      # Add it back to normalize

# LEARNING: Comprehensive device validation prevents data loss
if [ ! -b "$TARGET_DEV" ]; then
    log_fatal "$TARGET_DEV is not a valid block device"
fi
log_info "✓ Device is valid: $TARGET_DEV"

# LEARNING: Prevent writing to mounted devices
if is_device_mounted "$TARGET_DEV"; then
    log_fatal "$TARGET_DEV is currently mounted (mounted filesystems cannot be repartitioned)"
    log_error "  Please unmount all partitions on this device first:"
    log_error "  $ umount /dev/sdX*"
fi
log_info "✓ Device is not mounted"

# LEARNING: Prevent catastrophic data loss by checking for common patterns
# that indicate this might be the system drive
if grep -q "/dev/.*\s/$" /proc/mounts && grep -q "^$TARGET_DEV" /proc/mounts; then
    log_fatal "SAFETY CHECK FAILED: $TARGET_DEV appears to be your ROOT filesystem!"
    log_error "  Aborting to prevent complete system data loss"
fi
log_info "✓ Device is not the root filesystem"

# LEARNING: Detect partition names early so they are available even if 
# the partitioning phase is skipped.
P_SUFFIX=$(get_partition_suffix "$TARGET_DEV")
BOOT_PART="${TARGET_DEV}${P_SUFFIX}1"
ROOT_PART="${TARGET_DEV}${P_SUFFIX}2"
log_info "Target partitions identified: $BOOT_PART, $ROOT_PART"

# Final safety confirmation before destructive operations
log_warn ""
log_warn "FINAL WARNING: You are about to ERASE all data on: $TARGET_DEV"
log_warn "This operation CANNOT be undone."
if ! confirm "Are you absolutely certain you want to continue"; then
    log_error "Operation cancelled by user"
    exit 0
fi

# ============================================================================
# U-BOOT INSTALLATION
# ============================================================================

log_info ""
log_info "U-Boot Installation Phase..."

if confirm "Flash U-Boot to $TARGET_DEV"; then
    # LEARNING: Ensure U-Boot binaries are available, downloading/extracting if needed
    if ! ensure_uboot_binaries; then
        log_fatal "U-Boot binaries unavailable. Cannot proceed with flashing."
    fi
    
    log_info "Flashing idbloader.img to sector 64..."
    # LEARNING: dd seeks to the correct bootloader offset for RK3326
    # - Sector 64 = idbloader (0x20 sectors * 512 bytes = 16KB offset)
    # - notrunc: don't truncate (preserve existing data outside seek range)
    # - fsync: flush to disk before continuing
    dd if="$WORKING_DIR/idbloader.img" of="$TARGET_DEV" \
        seek=64 conv=notrunc,fsync bs=512 || log_fatal "U-Boot flashing failed"
    
    log_info "Flashing u-boot.itb to sector 16384..."
    # LEARNING: Sector 16384 = 0x4000 sectors * 512 bytes = 8MB offset
    dd if="$WORKING_DIR/u-boot.itb" of="$TARGET_DEV" \
        seek=16384 conv=notrunc,fsync bs=512 || log_fatal "U-Boot flashing failed"
    
    log_info "✓ U-Boot flashing complete"
else
    log_warn "U-Boot flashing skipped - device will not boot without valid U-Boot"
fi

# ============================================================================
# PARTITIONING PHASE
# ============================================================================

log_info ""
log_info "Partitioning Phase..."

if confirm "Partition $TARGET_DEV (BOOT and ROOT)"; then
    log_info "Calculating required BOOT partition size..."
    
    # LEARNING: du -ck calculates total disk usage
    # tail -n 1 gets the summary line (total)
    # cut -f 1 extracts the size in KB
    BOOT_SIZE_KB=$(du -ck \
        "$WORKING_DIR"/uInitrd \
        "$WORKING_DIR"/Image \
        "$WORKING_DIR"/boot.ini \
        "$WORKING_DIR/rk3326-r36ultra-linux.dtb" | tail -n 1 | cut -f 1)
    
    # LEARNING: Add buffer for safety (500MB) and U-Boot space (32MB)
    # Calculation: KB -> MB, add buffer, round up
    BOOT_END_MB=$(( (BOOT_SIZE_KB / 1024) + 500 + 32 ))
    
    log_info "  Boot files total: ~$(( BOOT_SIZE_KB / 1024 ))MB"
    log_info "  Boot partition size: ~${BOOT_END_MB}MB"
    
    log_info "Creating MBR partition table..."
    # LEARNING: mklabel msdos = Master Boot Record (traditional MBR partition table)
    # Not GPT, as older bootloaders may not support it
    parted -s "$TARGET_DEV" mklabel msdos || log_fatal "Failed to create partition table"
    
    log_info "Creating BOOT partition (FAT32)..."
    # LEARNING: 32MiB offset = leaves space for U-Boot
    parted -s "$TARGET_DEV" mkpart primary fat32 32MiB "${BOOT_END_MB}MiB" || \
        log_fatal "Failed to create BOOT partition"
    
    log_info "Creating ROOT partition (ext4)..."
    # LEARNING: 100% means use all remaining space
    parted -s "$TARGET_DEV" mkpart primary ext4 "${BOOT_END_MB}MiB" 100% || \
        log_fatal "Failed to create ROOT partition"
    
    log_info "✓ Partitions created successfully"
    
    # LEARNING: Detect partition naming based on device type
    P_SUFFIX=$(get_partition_suffix "$TARGET_DEV")
    BOOT_PART="${TARGET_DEV}${P_SUFFIX}1"
    ROOT_PART="${TARGET_DEV}${P_SUFFIX}2"
    
    log_info "Detected partition names:"
    log_info "  BOOT: $BOOT_PART"
    log_info "  ROOT: $ROOT_PART"
    
    # LEARNING: Verify partitions exist before attempting to format
    if [ ! -b "$BOOT_PART" ] || [ ! -b "$ROOT_PART" ]; then
        log_fatal "Partition devices not found after creation"
    fi
    
    if confirm "Format $BOOT_PART as BOOT (FAT32) and $ROOT_PART as ROOT (ext4)"; then
        log_info "Formatting BOOT partition..."
        # LEARNING: -n flag sets filesystem label (useful for troubleshooting)
        mkfs.vfat -n BOOT "$BOOT_PART" || log_fatal "Failed to format BOOT partition"
        
        log_info "Formatting ROOT partition..."
        mkfs.ext4 -L ROOT "$ROOT_PART" || log_fatal "Failed to format ROOT partition"
        
        log_info "✓ Partitions formatted successfully"
    fi
    
    # ========================================================================
    # PARTUUID CAPTURE (Critical for bootloader)
    # ========================================================================
    
    log_info ""
    log_info "Capturing partition UUIDs..."
    
    # LEARNING: PARTUUID is partition-table UUID (unique, persistent across reboots)
    # blkid -s PARTUUID -o value extracts just the UUID value (not the full output)
    TARGET_UUID=$(blkid -s PARTUUID -o value "$ROOT_PART" 2>/dev/null)
    
    # LEARNING: Validation ensures we have a valid UUID before using it
    if [ -z "$TARGET_UUID" ]; then
        log_fatal "Could not read PARTUUID from $ROOT_PART"
        log_error "  This usually means the partition table wasn't fully initialized"
        log_error "  Try: sudo partprobe $TARGET_DEV"
    fi
    
    log_info "✓ ROOT PARTUUID: $TARGET_UUID"
    
    # ========================================================================
    # MOUNT PARTITIONS
    # ========================================================================
    
    if confirm "Mount partitions to $BOOTFS and $ROOTFS"; then
        # LEARNING: Pre-check prevents remounting errors
        if is_device_mounted "$BOOT_PART"; then
            log_warn "$BOOT_PART is already mounted, skipping"
        else
            log_info "Mounting $BOOT_PART to $BOOTFS..."
            mkdir -p "$BOOTFS"
            mount "$BOOT_PART" "$BOOTFS" || log_fatal "Failed to mount BOOT partition"
        fi
        
        if is_device_mounted "$ROOT_PART"; then
            log_warn "$ROOT_PART is already mounted, skipping"
        else
            log_info "Mounting $ROOT_PART to $ROOTFS..."
            mkdir -p "$ROOTFS"
            mount "$ROOT_PART" "$ROOTFS" || log_fatal "Failed to mount ROOT partition"
        fi
        
        log_info "✓ Partitions mounted"
    fi
fi

# ============================================================================
# ROOTFS VALIDATION
# ============================================================================

log_info ""
log_info "Validating root filesystem..."

if [ ! -d "$ROOTFS/usr/bin" ]; then
    # LEARNING: Instead of failing, check if we can help the user by extracting the rootfs
    ROOTFS_TAR=$(find "$WORKING_DIR" -maxdepth 1 -name "alpine-minirootfs-*-aarch64.tar.gz" | head -n 1)
    
    if [ -n "$ROOTFS_TAR" ]; then
        if confirm "Root filesystem is empty. Extract $(basename "$ROOTFS_TAR") to $ROOTFS"; then
            log_info "Extracting Alpine rootfs... (this may take a moment)"
            tar -xzf "$ROOTFS_TAR" -C "$ROOTFS" --strip-components=0 || log_fatal "Extraction failed"
            log_info "✓ Rootfs extracted successfully"
        fi
    fi
fi

if [ ! -d "$ROOTFS/usr/bin" ]; then
    log_fatal "Root filesystem structure incomplete at $ROOTFS"
    log_error "  Possible causes:"
    log_error "  - alpine-minirootfs was not extracted"
    log_error "  - $ROOT_PART is not mounted"
    log_error "  - Files are in wrong location"
    log_error ""
    log_error "  To continue after fixing:"
    log_error "  1. Mount the ROOT partition: mount $ROOT_PART $ROOTFS"
    log_error "  2. Extract minirootfs: tar -xzf alpine-minirootfs-*.tar.gz -C $ROOTFS"
    log_error "  3. Re-run this script"
fi
log_info "✓ Root filesystem structure valid"

# ============================================================================
# PACKAGE INSTALLATION (via chroot)
# ============================================================================

log_info ""
log_info "Package Installation Phase (via chroot)..."

if confirm "Install Alpine packages (EmulationStation, XFCE, etc.) via chroot"; then
    # LEARNING: chroot changes the root directory for a process
    # This allows us to run Alpine package manager in the ARM target rootfs
    
    if ! command -v chroot &>/dev/null; then
        log_fatal "chroot command not available (required for package installation)"
    fi
    
    log_info "Configuring network and virtual filesystems for chroot..."
    # LEARNING: DNS resolution requires resolv.conf inside the chroot
    cp /etc/resolv.conf "$ROOTFS/etc/resolv.conf"
    
    # LEARNING: Bind-mounting host kernel interfaces is required for many packages
    mount --bind /dev "$ROOTFS/dev"
    mount --bind /proc "$ROOTFS/proc"
    mount --bind /sys "$ROOTFS/sys"

    # Set a trap to ensure we unmount even if the installation fails
    trap 'umount "$ROOTFS/dev" "$ROOTFS/proc" "$ROOTFS/sys" 2>/dev/null || true' EXIT

    # LEARNING: For handheld hardware, using Alpine Edge for all components
    # prevents dependency conflicts (broken indexes) between stable and rolling releases.
    cat > "$ROOTFS/etc/apk/repositories" << EOF
http://dl-cdn.alpinelinux.org/alpine/edge/main
http://dl-cdn.alpinelinux.org/alpine/edge/community
http://dl-cdn.alpinelinux.org/alpine/edge/testing
# LEARNING: For handheld hardware, the postmarketOS 'master' (rolling) branch
# provides the most reliable aarch64 builds for gaming-specific packages.
http://mirror.postmarketos.org/postmarketos/master
EOF
    
    log_info "Installing packages via chroot..."
    # LEARNING: Each package serves a specific purpose:
    # - emulationstation: retro game launcher
    # - xfce4, xfce4-terminal: desktop environment
    # - xorg-server, xf86-video-modesetting: X11 display server
    # - xinit, xrandr: display configuration
    # - bc: calculator (needed for LED speed control)
    # - triggerhappy: key event daemon (manual binary deployment)
    # - mesa-dri-gallium, mesa-egl, mesa-gbm: Hardware acceleration for Mali GPU
    
    # Allow untrusted for 3rd party repos (like postmarketos) if keys aren't imported yet
    APK_OPTS="--allow-untrusted"
    chroot "$ROOTFS" apk update $APK_OPTS || log_fatal "Failed to update package cache"
    chroot "$ROOTFS" apk add $APK_OPTS \
        emulationstation \
        xfce4 \
        xfce4-terminal \
        xorg-server \
        xf86-video-modesetting \
        xinit \
        xrandr \
        bc \
        openssh \
        mesa-dri-gallium \
        mesa-egl \
        mesa-gbm \
        || log_fatal "Failed to install packages"
    
    # LEARNING: Manual deployment of platform-specific binaries that are not in repos.
    if [ -f "$WORKING_DIR/triggerhappy/thd" ]; then
        log_info "Deploying local 'thd' binary from $WORKING_DIR/triggerhappy/..."
        mkdir -p "$ROOTFS/usr/local/bin"
        cp "$WORKING_DIR/triggerhappy/thd" "$ROOTFS/usr/local/bin/thd"
        chmod +x "$ROOTFS/usr/local/bin/thd"
        log_info "✓ triggerhappy binary (thd) deployed successfully"
    fi

    log_info "✓ Packages installed successfully"

    # LEARNING: Always clean up temporary files and mounts used for chroot
    # to ensure the target system remains in a "clean" state.
    umount "$ROOTFS/dev" "$ROOTFS/proc" "$ROOTFS/sys"
    rm -f "$ROOTFS/etc/resolv.conf"
    
    trap - EXIT
fi

# LEARNING: Verify bc is available (required by LED control scripts)
if [ ! -x "$ROOTFS/usr/bin/bc" ] && [ ! -x "$ROOTFS/bin/bc" ]; then
    log_error "WARNING: 'bc' (calculator) not found in target system"
    log_error "  LED speed control requires 'bc' to perform floating-point math"
    log_error "  Install it with: apk add bc"
fi

# ============================================================================
# LED MANAGEMENT DEPLOYMENT
# ============================================================================

log_info ""
log_info "LED Management System Deployment..."

if confirm "Deploy LED Management system"; then
    log_info "Creating LED daemon wrapper script..."
    
    # LEARNING: Create wrapper script that calls the embedded daemon
    # Wrappers allow easier updates without rebuilding entire system
    cat > "$ROOTFS/usr/local/bin/emulationstation-wrapper" << 'EOF'
#!/bin/sh
# Wrapper script for EmulationStation with LED integration
# Turns off LEDs when emulation starts
echo "off" > /tmp/led_pattern 2>/dev/null || true
exec /usr/bin/emulationstation "$@"
EOF
    chmod +x "$ROOTFS/usr/local/bin/emulationstation-wrapper"
    
    log_info "✓ LED management system deployed"
fi

# ============================================================================
# X11 CONFIGURATION
# ============================================================================

log_info ""
log_info "X11 Display Configuration..."

mkdir -p "$ROOTFS/etc/X11/xorg.conf.d"
cat > "$ROOTFS/etc/X11/xorg.conf.d/40-monitor.conf" << 'EOF'
# R36 Ultra display configuration
# The R36 Ultra has a 720x720 square DSI display
# Driver: modesetting (generic KMS driver)

Section "Monitor"
    Identifier "DSI-1"
    Option "Rotate" "normal"
EndSection

Section "Device"
    Identifier "Default Device"
    Driver "modesetting"
    Option "AccelMethod" "glamor"  # LEARNING: Hardware acceleration for performance
EndSection

Section "Screen"
    Identifier "Default Screen"
    Device "Default Device"
    Monitor "DSI-1"
EndSection
EOF

log_info "✓ X11 configuration deployed"

# ============================================================================
# BOOT FILE DEPLOYMENT
# ============================================================================

log_info ""
log_info "Boot File Deployment..."

if confirm "Copy boot files to BOOT partition"; then
    # LEARNING: Ensure the mount point exists and the device is actually mounted.
    mkdir -p "$BOOTFS"
    if ! is_device_mounted "$BOOT_PART"; then
        log_info "Attempting to mount $BOOT_PART to $BOOTFS..."
        mount "$BOOT_PART" "$BOOTFS" || log_fatal "Failed to mount BOOT partition."
    fi

    if is_device_mounted "$BOOT_PART"; then
        # LEARNING: Re-capture UUID if the variable was lost or partitioning skipped
        if [ -z "${TARGET_UUID:-}" ]; then
            TARGET_UUID=$(blkid -s PARTUUID -o value "$ROOT_PART" 2>/dev/null)
        fi

        if [ -z "$TARGET_UUID" ]; then
            log_fatal "TARGET_UUID is empty - cannot inject into boot.ini"
        fi
        
        log_info "Injecting PARTUUID ($TARGET_UUID) into boot.ini..."
        TARGET_UUID_ESCAPED=$(escape_sed_replacement "$TARGET_UUID")
        
        # Replace the placeholder in boot.ini and write to the SD card
        sed "s/\${root_uuid}/${TARGET_UUID_ESCAPED}/g" \
            "$WORKING_DIR/boot.ini" > "$BOOTFS/boot.ini" && sync || \
            log_fatal "Failed to create boot.ini"
        
        log_info "Copying kernel and system files..."
        for file in uInitrd Image rk3326-r36ultra-linux.dtb; do
            if [ -f "$WORKING_DIR/$file" ]; then
                log_info "  Copying $file..."
                cp "$WORKING_DIR/$file" "$BOOTFS/" || log_fatal "Failed to copy $file"
                verify_copy "$WORKING_DIR/$file" "$BOOTFS/$file" || exit 1
            fi
        done
        
        if [ -d "$WORKING_DIR/dtb" ]; then
            log_info "  Copying additional DTB files..."
            for dtb_file in "$WORKING_DIR"/dtb/*.dtb; do
                if [ -f "$dtb_file" ]; then
                    cp "$dtb_file" "$BOOTFS/"
                    verify_copy "$dtb_file" "$BOOTFS/$(basename "$dtb_file")" || exit 1
                fi
            done
        fi
        
        sync
        log_info "✓ Boot files successfully deployed and verified"
    else
        log_error "BOOT partition is not mounted. Skipping deployment."
    fi
fi

# ============================================================================
# COMPLETION
# ============================================================================

log_info ""
log_info "================================================================================"
log_info "✓ Integration Complete!"
log_info "================================================================================"
log_info ""
log_info "Summary:"
log_info "  Target Device:     $TARGET_DEV"
log_info "  BOOT Partition:    $BOOT_PART"
log_info "  ROOT Partition:    $ROOT_PART"
log_info "  BOOT Mounted At:   $BOOTFS"
log_info "  ROOT Mounted At:   $ROOTFS"
log_info "  ROOT UUID:         $TARGET_UUID"
log_info ""
log_info "Next steps:"
log_info "  1. Mount partitions (if not already done):"
log_info "     sudo mount $BOOT_PART $BOOTFS"
log_info "     sudo mount $ROOT_PART $ROOTFS"
log_info ""
log_info "  2. Extract Alpine minirootfs:"
log_info "     sudo tar -xzf alpine-minirootfs-*.tar.gz -C $ROOTFS"
log_info ""
log_info "  3. Re-run this script to complete setup"
log_info ""
log_info "Log file saved to: $LOG_FILE"
log_info "================================================================================"
