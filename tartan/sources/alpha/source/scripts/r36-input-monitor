#!/usr/bin/env python3
"""
R36 Ultra Diagnostic & Input Monitor Service - CORRECTED VERSION

LEARNING: This script handles:
1. Joystick input detection and monitoring
2. FN button combination detection
3. LED color cycling via hardware buttons
4. Signal ready state over USB gadget interface

The script uses the evdev library to access Linux input devices directly.
"""

import sys
import os
import time
from pathlib import Path

# LEARNING: evdev provides access to Linux input devices (/dev/input/event*)
try:
    import evdev
    from evdev import ecodes
except ImportError:
    print("ERROR: evdev module not found", file=sys.stderr)
    print("Install with: pip3 install evdev", file=sys.stderr)
    sys.exit(1)

# ============================================================================
# CONFIGURATION
# ============================================================================

# LEARNING: LED brightness values and color definitions
# Each tuple is (red, green, blue) with 0 = off, 255 = on
# NOTE: Modern RGB LEDs might need different range, but 0/255 is standard
LED_COLORS = [
    (255, 0, 0),      # Red
    (0, 255, 0),      # Green
    (0, 0, 255),      # Blue
    (255, 255, 0),    # Yellow
    (255, 255, 255),  # White
]

# LEARNING: Track which color we're on for cycling
current_color_index = 2  # Start at Blue

# LED control paths (Linux sysfs interface)
# These are provided by the LED subsystem kernel driver
LED_PATH_RED = "/sys/class/leds/joystick:red/brightness"
LED_PATH_GREEN = "/sys/class/leds/joystick:green/brightness"
LED_PATH_BLUE = "/sys/class/leds/joystick:blue/brightness"

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

def update_leds(red: int, green: int, blue: int) -> None:
    """
    Update LED colors via sysfs interface.
    
    LEARNING: This function writes to the Linux LED subsystem
    Parameters are 0-255 brightness values for each color
    """
    leds = {
        "red": red,
        "green": green,
        "blue": blue,
    }
    
    led_files = {
        "red": LED_PATH_RED,
        "green": LED_PATH_GREEN,
        "blue": LED_PATH_BLUE,
    }
    
    for color_name, brightness in leds.items():
        led_file = led_files[color_name]
        
        # LEARNING: Check if LED path exists before writing
        # Some systems might not have all LED colors available
        try:
            if Path(led_file).exists():
                with open(led_file, "w") as f:
                    # LEARNING: Write as 0 (off) or 1 (on) - binary brightness
                    # Some LEDs support 0-255, others only 0-1
                    value = min(255, brightness)  # Cap at 255
                    f.write(str(value))
        except (OSError, IOError) as e:
            print(f"WARNING: Failed to update LED {color_name}: {e}", file=sys.stderr)

def find_gamepad() -> evdev.InputDevice | None:
    """
    Scan for gamepad/joystick device.
    
    LEARNING: Returns the first device matching "joy" pattern in name
    Returns None if no gamepad found
    """
    try:
        devices = [evdev.InputDevice(path) for path in evdev.list_devices()]
    except Exception as e:
        print(f"ERROR: Failed to enumerate input devices: {e}", file=sys.stderr)
        return None
    
    # LEARNING: Filter devices by name - typical names include "joy", "gamepad", "joypad"
    gamepads = [d for d in devices if "joy" in d.name.lower()]
    
    if not gamepads:
        return None
    
    # Return first (primary) gamepad
    return gamepads[0]

def main() -> int:
    """
    Main event loop.
    
    LEARNING: Continuously reads input events from gamepad and processes them
    """
    global current_color_index
    
    # LEARNING: Signal SSH readiness over USB gadget interface
    # This indicates to host that device is ready for connection
    if Path("/sys/class/net/usb0").exists():
        print("INFO: USB gadget interface detected, signaling ready state...", file=sys.stderr)
        update_leds(0, 255, 0)  # Green = ready
    
    # Find gamepad device
    print("INFO: Scanning for gamepad device...", file=sys.stderr)
    gamepad = find_gamepad()
    
    if gamepad is None:
        print("ERROR: No joystick/gamepad device found!", file=sys.stderr)
        print("       Check that device is properly configured", file=sys.stderr)
        print("       Available devices:", file=sys.stderr)
        try:
            for dev_path in evdev.list_devices():
                dev = evdev.InputDevice(dev_path)
                print(f"         {dev.name} ({dev_path})", file=sys.stderr)
        except:
            pass
        return 1
    
    print(f"INFO: Found gamepad: {gamepad.name}", file=sys.stderr)
    
    try:
        fn_held = False
        
        print("INFO: R36 Input Monitor Active - listening for events...", file=sys.stderr)
        
        # LEARNING: read_loop() yields input events as they occur
        # This blocks until an event arrives
        for event in gamepad.read_loop():
            # LEARNING: EV_KEY events are button presses/releases
            if event.type == ecodes.EV_KEY:
                # LEARNING: Check for FN button (code 708 is BTN_F mapping)
                # event.value: 0 = released, 1 = pressed
                if event.code == ecodes.BTN_F or event.code == 708:
                    fn_held = (event.value == 1)
                    action = "held" if fn_held else "released"
                    print(f"DEBUG: FN button {action}", file=sys.stderr)
                
                # LEARNING: L3 is analog stick press (left thumbstick)
                # Toggle mouse emulation mode
                if event.code == ecodes.BTN_THUMBL and event.value == 1:
                    print("DEBUG: L3 pressed - toggling mouse mode", file=sys.stderr)
                
                # LEARNING: Color cycling via FN + DPAD combinations
                # FN held + directional input = cycle through colors
                if fn_held and event.value == 1:
                    if event.code == ecodes.KEY_LEFT:
                        # Left = previous color
                        current_color_index = (current_color_index - 1) % len(LED_COLORS)
                        print(f"DEBUG: Color LEFT - now index {current_color_index}", file=sys.stderr)
                        update_leds(*LED_COLORS[current_color_index])
                    
                    elif event.code == ecodes.KEY_RIGHT:
                        # Right = next color
                        current_color_index = (current_color_index + 1) % len(LED_COLORS)
                        print(f"DEBUG: Color RIGHT - now index {current_color_index}", file=sys.stderr)
                        update_leds(*LED_COLORS[current_color_index])
    
    except KeyboardInterrupt:
        print("INFO: Shutting down gracefully...", file=sys.stderr)
        return 0
    except Exception as e:
        print(f"ERROR: Unexpected error in event loop: {e}", file=sys.stderr)
        import traceback
        traceback.print_exc(file=sys.stderr)
        return 1
    
    return 0

# ============================================================================
# ENTRY POINT
# ============================================================================

if __name__ == "__main__":
    sys.exit(main())
